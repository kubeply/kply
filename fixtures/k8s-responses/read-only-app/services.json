{
  "apiVersion": "v1",
  "kind": "ServiceList",
  "metadata": {
    "resourceVersion": "1001"
  },
  "items": [
    {
      "apiVersion": "v1",
      "kind": "Service",
      "metadata": {
        "name": "checkout-http",
        "namespace": "shop"
      },
      "spec": {
        "type": "ClusterIP",
        "selector": {
          "app.kubernetes.io/name": "checkout-api"
        },
        "ports": [
          {
            "name": "http",
            "port": 80,
            "targetPort": "http",
            "protocol": "TCP",
            "appProtocol": "http"
          }
        ]
      }
    }
  ]
}
