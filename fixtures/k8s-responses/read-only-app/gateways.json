{
  "apiVersion": "gateway.networking.k8s.io/v1",
  "kind": "GatewayList",
  "metadata": {
    "resourceVersion": "1005"
  },
  "items": [
    {
      "apiVersion": "gateway.networking.k8s.io/v1",
      "kind": "Gateway",
      "metadata": {
        "name": "public-gateway",
        "namespace": "shop"
      },
      "spec": {
        "gatewayClassName": "public",
        "listeners": [
          {
            "name": "http",
            "hostname": "checkout.example.com",
            "port": 80,
            "protocol": "HTTP"
          },
          {
            "name": "https",
            "hostname": "checkout.example.com",
            "port": 443,
            "protocol": "HTTPS",
            "tls": {
              "mode": "Terminate",
              "certificateRefs": [
                {
                  "kind": "Secret",
                  "name": "checkout-tls"
                }
              ]
            }
          }
        ]
      }
    }
  ]
}
