{
  "apiVersion": "gateway.networking.k8s.io/v1",
  "kind": "HTTPRouteList",
  "metadata": {
    "resourceVersion": "2003"
  },
  "items": [
    {
      "apiVersion": "gateway.networking.k8s.io/v1",
      "kind": "HTTPRoute",
      "metadata": {
        "name": "checkout-public",
        "namespace": "shop"
      },
      "spec": {
        "hostnames": [
          "checkout.example.com"
        ],
        "parentRefs": [
          {
            "kind": "Gateway",
            "namespace": "shop",
            "name": "public-gateway",
            "sectionName": "https"
          }
        ],
        "rules": [
          {
            "matches": [
              {
                "path": {
                  "type": "PathPrefix",
                  "value": "/"
                }
              }
            ],
            "backendRefs": [
              {
                "kind": "Service",
                "name": "checkout-api",
                "port": 80,
                "weight": 1
              }
            ]
          }
        ]
      }
    },
    {
      "apiVersion": "gateway.networking.k8s.io/v1",
      "kind": "HTTPRoute",
      "metadata": {
        "name": "checkout-sandbox-header",
        "namespace": "shop"
      },
      "spec": {
        "parentRefs": [
          {
            "kind": "Gateway",
            "namespace": "platform",
            "name": "shared-gateway",
            "sectionName": "preview"
          }
        ],
        "rules": [
          {
            "matches": [
              {
                "headers": [
                  {
                    "type": "Exact",
                    "name": "x-kply-session",
                    "value": "checkout-plan"
                  }
                ]
              }
            ],
            "backendRefs": [
              {
                "kind": "Service",
                "name": "checkout-api-sandbox",
                "port": 8080
              }
            ]
          }
        ]
      }
    }
  ]
}
