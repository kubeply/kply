---
source: crates/kply-core/src/manifest.rs
expression: value
---
{
  "apiVersion": "v1",
  "kind": "Service",
  "metadata": {
    "annotations": {
      "kply.dev/image": "registry.example.com/checkout/api:v2",
      "kply.dev/route-strategy": "header",
      "kply.dev/workload": "checkout/Deployment/checkout-api"
    },
    "labels": {
      "app.kubernetes.io/component": "api",
      "kply.dev/app": "checkout",
      "kply.dev/managed-by": "kply",
      "kply.dev/session-id": "session-123",
      "kply.dev/session-name": "checkout-test"
    },
    "name": "session-123-service",
    "namespace": "checkout"
  },
  "spec": {
    "ports": [
      {
        "name": "http",
        "port": 80,
        "targetPort": 80
      }
    ],
    "selector": {
      "app.kubernetes.io/component": "api",
      "kply.dev/app": "checkout",
      "kply.dev/managed-by": "kply",
      "kply.dev/session-id": "session-123",
      "kply.dev/session-name": "checkout-test"
    }
  }
}
